#!/usr/bin/env bash
# aim-grok CLI wrapper — routes to local A.I.M. engine
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS_ROOT="$ROOT/aim-agy_os"
VENV_PY="$OS_ROOT/venv/bin/python3"
CLI="$OS_ROOT/.aim_core/aim_cli.py"

if [[ ! -x "$VENV_PY" ]]; then
  echo "[aim-grok] venv missing. Run: bash aim-agy_os/setup.sh" >&2
  exit 1
fi
if [[ ! -f "$CLI" ]]; then
  echo "[aim-grok] aim_cli.py missing at $CLI" >&2
  exit 1
fi

# Pin host family for reincarnate spawn (issue #34) — never fall through to AGY
export AIM_VESSEL_CLI="${AIM_VESSEL_CLI:-grok}"
export AIM_HOST="${AIM_HOST:-grok}"

export PYTHONPATH="${OS_ROOT}:${OS_ROOT}/.aim_core${PYTHONPATH:+:$PYTHONPATH}"
exec "$VENV_PY" "$CLI" "$@"
